{
  "expo": {
    "name": "NDPass",
    "slug": "ndpass",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "ndpass",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#080810"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gios.ndpass",
      "infoPlist": {
        "NSCameraUsageDescription": "NDPass uses your camera to scan movie tickets",
        "NSPhotoLibraryUsageDescription": "NDPass accesses your photos to import ticket images"
      },
      "entitlements": {
        "com.apple.security.application-groups": ["group.com.gios.ndpass"]
      }
    },
    "plugins": [
      "expo-router",
      "expo-image-picker",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#E8D5B7"
        }
      ],
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
